// SAFE IDLE FIRMWARE - ESP32 + L298N + PCA9685
// Mục tiêu: nạp vào ESP32 để robot KHÔNG hoạt động gì cả.
// - Motor dừng
// - PWM motor = 0
// - PCA9685 tắt toàn bộ output PWM
// - Không WiFi, không WebSocket, không chạy servo

#include <Arduino.h>
#include <Wire.h>
#include <WiFi.h>

// ================== PINOUT L298N ==================
#define ENA 13
#define IN1 12
#define IN2 14

#define ENB 25
#define IN3 27
#define IN4 26

// ================== I2C PCA9685 ==================
#define I2C_SDA 21
#define I2C_SCL 22
#define PCA9685_ADDR 0x40

// PCA9685 registers
#define PCA_MODE1        0x00
#define PCA_ALL_LED_ON_L 0xFA
#define PCA_ALL_LED_ON_H 0xFB
#define PCA_ALL_LED_OFF_L 0xFC
#define PCA_ALL_LED_OFF_H 0xFD

// ================== HÀM GHI I2C PCA9685 ==================
void pcaWrite(uint8_t reg, uint8_t value) {
  Wire.beginTransmission(PCA9685_ADDR);
  Wire.write(reg);
  Wire.write(value);
  Wire.endTransmission();
}

// Tắt toàn bộ xung PWM của PCA9685
void pca9685AllOff() {
  Wire.begin(I2C_SDA, I2C_SCL);
  delay(50);

  // Tắt toàn bộ 16 kênh PWM
  pcaWrite(PCA_ALL_LED_ON_L, 0x00);
  pcaWrite(PCA_ALL_LED_ON_H, 0x00);
  pcaWrite(PCA_ALL_LED_OFF_L, 0x00);
  pcaWrite(PCA_ALL_LED_OFF_H, 0x10);  // bit full-off

  // Đưa PCA9685 vào sleep để ngừng PWM
  pcaWrite(PCA_MODE1, 0x10);

  delay(50);
}

// ================== MOTOR SAFE STOP ==================
void motorPinsSafe() {
  pinMode(ENA, OUTPUT);
  pinMode(IN1, OUTPUT);
  pinMode(IN2, OUTPUT);

  pinMode(ENB, OUTPUT);
  pinMode(IN3, OUTPUT);
  pinMode(IN4, OUTPUT);

  // Tắt enable motor trước
  digitalWrite(ENA, LOW);
  digitalWrite(ENB, LOW);

  // Tắt toàn bộ chân chiều
  digitalWrite(IN1, LOW);
  digitalWrite(IN2, LOW);
  digitalWrite(IN3, LOW);
  digitalWrite(IN4, LOW);
}

// ================== SETUP ==================
void setup() {
  Serial.begin(115200);
  delay(500);

  Serial.println();
  Serial.println("====================================");
  Serial.println("ESP32 SAFE IDLE FIRMWARE");
  Serial.println("Motor: OFF");
  Serial.println("Servo PWM PCA9685: OFF");
  Serial.println("WiFi: OFF");
  Serial.println("====================================");

  // Tắt WiFi/Bluetooth để ESP32 đứng yên, ít nhiễu
  WiFi.mode(WIFI_OFF);
  btStop();

  // Dừng motor
  motorPinsSafe();

  // Tắt output PCA9685 nếu đang kết nối
  pca9685AllOff();

  Serial.println("SAFE IDLE READY.");
}

// ================== LOOP ==================
void loop() {
  // Luôn giữ motor ở trạng thái dừng
  motorPinsSafe();

  // Không làm gì khác
  Serial.println("SAFE IDLE - no motor, no servo, no WiFi");
  delay(3000);
}
